{
  "name": "idea-gauntlet",
  "version": "0.3.0",
  "description": "Stress-test product ideas with adversarial agents, synthetic users, and court-style critique.",
  "type": "module",
  "bin": {
    "idea-gauntlet": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node -e \"try{require('fs').accessSync('dist/postinstall.js');require('child_process').execSync('node dist/postinstall.js',{stdio:'inherit'})}catch(e){process.exit(0)}\"",
    "build": "tsup src/index.ts src/cli/index.ts src/postinstall.ts --format esm --dts --clean",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "product-discovery",
    "validation",
    "adversarial",
    "startup",
    "idea"
  ],
  "license": "MIT",
  "author": "Thuong180702 (https://github.com/Thuong180702)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thuong180702/IdeaGauntlet.git"
  },
  "homepage": "https://github.com/Thuong180702/IdeaGauntlet#readme",
  "bugs": {
    "url": "https://github.com/Thuong180702/IdeaGauntlet/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "playwright": "^1.40.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
